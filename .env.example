# WordPress REST API のベース URL（末尾スラッシュなし、HTTPS 必須）
# 例: https://your-domain.com
WP_API_URL=https://your-domain.com

# 専用ユーザー名（Editor 権限推奨。Administrator は避ける）
WP_USERNAME=claude-poster

# Application Password（WordPress 管理画面で発行したスペース込みのパスワード）
# 値にスペースが含まれるため、ダブルクォートで囲む
WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
